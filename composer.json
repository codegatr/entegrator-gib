{
    "name": "codegatr/entegrator-gib",
    "description": "GİB Onaylı e-Fatura Özel Entegratör Kütüphanesi — UBL-TR 2.1, XAdES-BES, GİB Servis Bağlantıları",
    "type": "library",
    "license": "MIT",
    "keywords": ["e-fatura", "gib", "ubl-tr", "ubl", "xades", "turkey", "efatura", "entegrator"],
    "homepage": "https://entegrator.codega.com.tr",
    "support": {
        "issues": "https://github.com/codegatr/entegrator-gib/issues",
        "source": "https://github.com/codegatr/entegrator-gib"
    },
    "authors": [
        {
            "name": "CODEGA",
            "email": "info@codega.com.tr",
            "homepage": "https://codega.com.tr"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-soap": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CodegaGib\\": "src/CodegaGib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodegaGib\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "example:basic": "php examples/01_basic_invoice.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
